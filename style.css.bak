body {
    margin: 0;
    font-family: monospace;
    background: #0e1018;
    color: #e8ffe8;
}

.app {
    max-width: 1100px;
    margin: auto;
    padding: 20px;
}

h1 {
    font-size: 40px;
    margin-bottom: 0;
}

.subtitle {
    color: #9aff9a;
    margin-top: 5px;
}

.panel {
    background: #181a28;
    border: 2px solid #3cff7b;
    padding: 16px;
    margin: 16px 0;
    box-shadow: 0 0 10px rgba(60, 255, 123, 0.18);
}

textarea,
input {
    width: 100%;
    box-sizing: border-box;
    background: #08090f;
    color: #e8ffe8;
    border: 1px solid #3cff7b;
    padding: 12px;
    font-family: monospace;
    font-size: 16px;
}

button {
    margin-top: 12px;
    padding: 12px 18px;
    background: #3cff7b;
    color: #101018;
    border: none;
    font-family: monospace;
    font-weight: bold;
    cursor: pointer;
}

button:hover {
    filter: brightness(1.2);
}

.buttonRow {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

.creature {
    font-size: 90px;
    text-align: center;
    padding: 20px;
    animation: wormPulse 1.5s infinite;
}

.small {
    color: #a8ffbf;
    font-size: 14px;
}

.guideline {
    border-color: #ffe66d;
    box-shadow: 0 0 10px rgba(255, 230, 109, 0.2);
}

pre {
    white-space: pre-wrap;
    background: #08090f;
    padding: 12px;
    border: 1px solid #303050;
    min-height: 80px;
    overflow-x: auto;
}

@keyframes wormPulse {
    0% { transform: scaleX(1) scaleY(1); }
    50% { transform: scaleX(1.2) scaleY(0.9); }
    100% { transform: scaleX(1) scaleY(1); }
}

@media (max-width: 750px) {
    .grid {
        grid-template-columns: 1fr;
    }
}
